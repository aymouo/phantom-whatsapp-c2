# Phantom C2 — WhatsApp Bot

# Bot phone number will self-register on first message (first sender becomes operator)
# To lock to a specific number, set its JID (e.g. 2126XXXXXXXX@s.whatsapp.net)
OWNER_JID=

# Primary chat to forward device responses (optional, defaults to first operator chat)
# For group mode, set the group JID (e.g. 2126XXXXXXXX-1234567890@g.us)
ALERT_JID=

# Bot will auto-reply in this group (optional, requires ALERT_JID to be a group)
# Set to "true" to allow all group members to send commands
GROUP_MODE=false

# HTTP API port
PORT=3000

# Auth state directory (persist for Koyeb volume mount)
AUTH_DIR=./auth_info

# SQLite database path
DB_PATH=./data.db
