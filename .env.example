# Phantom C2 — WhatsApp Bot

# Your WhatsApp number in international format (digits only, no +)
# e.g. 212723643165 for +212 723-643165
# This generates a pairing code so you can link bot from WhatsApp Desktop
PHONE_NUMBER=

# Operator's WhatsApp JID (e.g. 2126XXXXXXXX@s.whatsapp.net)
# If not set, falls back to PHONE_NUMBER to derive JID
OWNER_JID=

# GROUP_MODE=true → bot auto-creates "Phantom C2 Ops" group with operator on connect
# Interactive lists (buttons) work in groups but NOT in self-chat (same number)
# Commands accepted from both DM and group; interactive UI routes to group
# Group JID is persisted in group_jid.txt for reconnection
GROUP_MODE=false

# HTTP API port
PORT=3000

# Auth state directory (persist for Koyeb volume mount)
AUTH_DIR=./auth_info

# SQLite database path
DB_PATH=./data.db
